---
import { ChevronRight, Menu, Moon, Sun, X } from "@lucide/astro";
import Button from "./Button.astro";

const { pathname } = Astro.url;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const relativePathname = baseUrl ? pathname.replace(baseUrl, "") : pathname;
const normalizedPathname = relativePathname.replace(/\/$/, "");

const isHome =
	normalizedPathname === "" || normalizedPathname === "/index.html";
const isNotes =
	normalizedPathname === "/notes" || normalizedPathname.startsWith("/notes/");
---

<nav
  class="bg-surface dark:bg-background docked full-width top-0 z-50 fixed w-full border-b border-outline-variant/30"
>
  <div
    class="flex justify-between items-center w-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto h-20"
  >
    <a
      href={import.meta.env.BASE_URL}
      class="font-display-lg text-[32px] text-primary cursor-pointer leading-none select-none no-underline"
    >
      ohwire
    </a>
    <div class="hidden md:flex items-center space-x-2">
      <a
        class={`px-4 py-1.5 rounded-full font-label-md text-label-md transition-[color,background-color,transform] duration-150 ease-[var(--ease-custom-out)] active:scale-[0.97] no-underline select-none ${
          isHome
            ? "bg-primary/10 text-primary dark:bg-primary/15 font-semibold"
            : "text-secondary dark:text-secondary-fixed-dim hover:text-primary hover:bg-secondary/5 dark:hover:bg-secondary-container/10"
        }`}
        href={import.meta.env.BASE_URL}
      >
        Home
      </a>
      <a
        class={`px-4 py-1.5 rounded-full font-label-md text-label-md transition-[color,background-color,transform] duration-150 ease-[var(--ease-custom-out)] active:scale-[0.97] no-underline select-none ${
          isNotes
            ? "bg-primary/10 text-primary dark:bg-primary/15 font-semibold"
            : "text-secondary dark:text-secondary-fixed-dim hover:text-primary hover:bg-secondary/5 dark:hover:bg-secondary-container/10"
        }`}
        href={`${baseUrl}/notes`}
      >
        Notes
      </a>
    </div>
    <div class="flex items-center gap-4">
      <div class="hidden sm:flex items-center gap-4 mr-2">
        <a
          href="https://x.com/ohwiredev"
          target="_blank"
          rel="noopener noreferrer"
          class="text-on-surface dark:text-on-background hover:text-primary transition-[color,transform] duration-150 ease-[var(--ease-custom-out)] active:scale-[0.97]"
          aria-label="X (Twitter)"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
            ></path>
          </svg>
        </a>
        <a
          href="https://github.com/ohwiredev"
          target="_blank"
          rel="noopener noreferrer"
          class="text-on-surface dark:text-on-background hover:text-primary transition-[color,transform] duration-150 ease-[var(--ease-custom-out)] active:scale-[0.97]"
          aria-label="GitHub"
        >
          <svg
            class="w-5 h-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
            ></path>
            <path d="M9 18c-4.51 2-5-2-7-2"></path>
          </svg>
        </a>
      </div>
      <button
        class="theme-toggle-btn text-on-surface dark:text-on-background hover:text-primary cursor-pointer p-2 rounded-full hover:bg-secondary/5 dark:hover:bg-secondary-container/10 transition-[color,background-color,transform] duration-150 ease-[var(--ease-custom-out)] active:scale-[0.97] hidden sm:inline-block"
        aria-label="Toggle theme"
      >
        <Sun class="w-5 h-5 hidden dark:block" />
        <Moon class="w-5 h-5 block dark:hidden" />
      </button>
      <button
        class="md:hidden text-on-surface cursor-pointer p-2 rounded-full hover:bg-secondary/5 transition-[background-color,transform] duration-150 ease-[var(--ease-custom-out)] active:scale-[0.97] relative z-60"
        id="mobile-menu-btn"
        aria-label="Toggle menu"
      >
        <Menu class="w-6 h-6 block" id="menu-icon-hamburger" />
        <X class="w-6 h-6 hidden" id="menu-icon-close" />
      </button>
    </div>
  </div>
</nav>

<!-- Mobile Menu Floating Dropdown -->
<div
  id="mobile-menu-backdrop"
  class="fixed inset-0 bg-black/10 backdrop-blur-xs z-50 md:hidden opacity-0 pointer-events-none transition-opacity duration-300"
></div>

<div
  id="mobile-menu"
  class="fixed top-24 left-5 right-5 bg-surface-container border border-outline-variant/30 z-60 flex flex-col md:hidden transition-[transform,opacity] duration-200 ease-[var(--ease-custom-out)] transform origin-top-right opacity-0 scale-95 pointer-events-none shadow-2xl rounded-2xl p-6"
>
  <!-- Navigation Links -->
  <div class="flex flex-col space-y-4">
    <a
      class={`text-xl font-semibold font-label-md no-underline py-3 px-4 rounded-xl transition-[color,background-color,transform] duration-150 ease-[var(--ease-custom-out)] active:scale-[0.97] flex items-center justify-between ${
        isHome ? "bg-primary/10 text-primary font-bold" : "text-on-surface hover:bg-secondary/5"
      }`}
      href={import.meta.env.BASE_URL}
    >
      <span>Home</span>
      <ChevronRight class="w-4 h-4 opacity-50" />
    </a>
    <a
      class={`text-xl font-semibold font-label-md no-underline py-3 px-4 rounded-xl transition-[color,background-color,transform] duration-150 ease-[var(--ease-custom-out)] active:scale-[0.97] flex items-center justify-between ${
        isNotes ? "bg-primary/10 text-primary font-bold" : "text-on-surface hover:bg-secondary/5"
      }`}
      href={`${baseUrl}/notes`}
    >
      <span>Notes</span>
      <ChevronRight class="w-4 h-4 opacity-50" />
    </a>
    <div class="pt-2">
      <Button
        href={`${baseUrl}/#newsletter-section`}
        variant="primary"
        size="md"
        class="w-full text-center py-3.5"
      >
        Subscribe
      </Button>
    </div>
  </div>

  <!-- Divider & Bottom Section -->
  <div class="mt-6 pt-5 border-t border-outline-variant/30 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <a
        href="https://x.com/ohwiredev"
        target="_blank"
        rel="noopener noreferrer"
        class="text-on-surface dark:text-on-background hover:text-primary transition-[color,background-color,transform] duration-150 ease-[var(--ease-custom-out)] active:scale-[0.97] p-2.5 rounded-full hover:bg-secondary/5"
        aria-label="X (Twitter)"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
          ></path>
        </svg>
      </a>
      <a
        href="https://github.com/ohwiredev"
        target="_blank"
        rel="noopener noreferrer"
        class="text-on-surface dark:text-on-background hover:text-primary transition-[color,background-color,transform] duration-150 ease-[var(--ease-custom-out)] active:scale-[0.97] p-2.5 rounded-full hover:bg-secondary/5"
        aria-label="GitHub"
      >
        <svg
          class="w-5 h-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
          ></path>
          <path d="M9 18c-4.51 2-5-2-7-2"></path>
        </svg>
      </a>
    </div>
    
    <button
      class="theme-toggle-btn text-on-surface dark:text-on-background hover:text-primary cursor-pointer p-2.5 rounded-full hover:bg-secondary/5 dark:hover:bg-secondary-container/10 transition-[color,background-color,transform] duration-150 ease-[var(--ease-custom-out)] active:scale-[0.97]"
      aria-label="Toggle theme"
    >
      <Sun class="w-5 h-5 hidden dark:block" />
      <Moon class="w-5 h-5 block dark:hidden" />
    </button>
  </div>
</div>

<script>
  const menuBtn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const backdrop = document.getElementById("mobile-menu-backdrop");
  const hamburgerIcon = document.getElementById("menu-icon-hamburger");
  const closeIcon = document.getElementById("menu-icon-close");

  const toggleMenu = () => {
    if (!menu || !backdrop || !hamburgerIcon || !closeIcon) return;
    const isOpen = !menu.classList.contains("pointer-events-none");
    
    if (isOpen) {
      // Close menu
      menu.classList.add("opacity-0", "scale-95", "pointer-events-none");
      menu.classList.remove("opacity-100", "scale-100");
      backdrop.classList.add("opacity-0", "pointer-events-none");
      backdrop.classList.remove("opacity-100");
      
      hamburgerIcon.classList.remove("hidden");
      hamburgerIcon.classList.add("block");
      closeIcon.classList.remove("block");
      closeIcon.classList.add("hidden");
    } else {
      // Open menu
      menu.classList.remove("opacity-0", "scale-95", "pointer-events-none");
      menu.classList.add("opacity-100", "scale-100");
      backdrop.classList.remove("opacity-0", "pointer-events-none");
      backdrop.classList.add("opacity-100");
      
      hamburgerIcon.classList.remove("block");
      hamburgerIcon.classList.add("hidden");
      closeIcon.classList.remove("hidden");
      closeIcon.classList.add("block");
    }
  };

  const closeMenu = () => {
    if (!menu || !backdrop || !hamburgerIcon || !closeIcon) return;
    menu.classList.add("opacity-0", "scale-95", "pointer-events-none");
    menu.classList.remove("opacity-100", "scale-100");
    backdrop.classList.add("opacity-0", "pointer-events-none");
    backdrop.classList.remove("opacity-100");
    
    hamburgerIcon.classList.remove("hidden");
    hamburgerIcon.classList.add("block");
    closeIcon.classList.remove("block");
    closeIcon.classList.add("hidden");
  };

  if (menuBtn && menu && backdrop) {
    menuBtn.addEventListener("click", toggleMenu);
    backdrop.addEventListener("click", closeMenu);

    // Close menu when a link is clicked
    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  }

  // Dark/Light Theme toggling logic
  const toggleTheme = () => {
    const isDark = document.documentElement.classList.contains("dark");
    if (isDark) {
      document.documentElement.classList.remove("dark");
      document.documentElement.classList.add("light");
      localStorage.setItem("theme", "light");
    } else {
      document.documentElement.classList.remove("light");
      document.documentElement.classList.add("dark");
      localStorage.setItem("theme", "dark");
    }
  };

  const themeButtons = document.querySelectorAll(".theme-toggle-btn");
  themeButtons.forEach((btn) => {
    btn.addEventListener("click", toggleTheme);
  });
</script>
