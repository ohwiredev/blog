---
import { Menu, X } from "@lucide/astro";
import Button from "./Button.astro";

const { pathname } = Astro.url;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const relativePathname = baseUrl ? pathname.replace(baseUrl, "") : pathname;
const normalizedPathname = relativePathname.replace(/\/$/, "");

const isHome =
	normalizedPathname === "" || normalizedPathname === "/index.html";
const isNotes =
	normalizedPathname === "/notes" || normalizedPathname.startsWith("/notes/");
---
<nav class="bg-surface dark:bg-background docked full-width top-0 z-50 fixed w-full border-b border-outline-variant/30">
  <div class="flex justify-between items-center w-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto h-20">
    <a href={import.meta.env.BASE_URL} class="font-display-lg text-[32px] text-primary dark:text-primary-container cursor-pointer leading-none select-none no-underline">
      ohwire
    </a>
    <div class="hidden md:flex items-center space-x-2">
      <a
        class={`px-4 py-1.5 rounded-full font-label-md text-label-md transition-all duration-200 no-underline select-none ${
          isHome
            ? "bg-primary/10 text-primary dark:bg-primary-container/15 dark:text-primary-container font-semibold"
            : "text-secondary dark:text-secondary-fixed-dim hover:text-primary dark:hover:text-primary-container hover:bg-secondary/5 dark:hover:bg-secondary-container/10"
        }`}
        href={import.meta.env.BASE_URL}
      >
        Home
      </a>
      <a
        class={`px-4 py-1.5 rounded-full font-label-md text-label-md transition-all duration-200 no-underline select-none ${
          isNotes
            ? "bg-primary/10 text-primary dark:bg-primary-container/15 dark:text-primary-container font-semibold"
            : "text-secondary dark:text-secondary-fixed-dim hover:text-primary dark:hover:text-primary-container hover:bg-secondary/5 dark:hover:bg-secondary-container/10"
        }`}
        href={`${import.meta.env.BASE_URL}/notes`}
      >
        Notes
      </a>
    </div>
    <div class="flex items-center gap-4">
      <div class="hidden sm:flex items-center gap-4 mr-2">
        <a href="https://x.com/ohwiredev" target="_blank" rel="noopener noreferrer" class="text-on-surface dark:text-on-background hover:text-primary dark:hover:text-primary-container transition-colors duration-200" aria-label="X (Twitter)">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a href="https://github.com/ohwiredev" target="_blank" rel="noopener noreferrer" class="text-on-surface dark:text-on-background hover:text-primary dark:hover:text-primary-container transition-colors duration-200" aria-label="GitHub">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
            <path d="M9 18c-4.51 2-5-2-7-2" />
          </svg>
        </a>
      </div>
      <Button href={`${import.meta.env.BASE_URL}/#newsletter-section`} variant="primary" size="sm">
        Subscribe
      </Button>
      <button class="md:hidden text-on-surface cursor-pointer" id="mobile-menu-btn">
        <Menu class="w-6 h-6" />
      </button>
    </div>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 bg-surface/98 z-60 flex flex-col items-center justify-center space-y-8 md:hidden transition-all duration-300 translate-x-full">
  <button id="close-menu-btn" class="absolute top-6 right-6 text-on-surface">
    <X class="w-8 h-8" />
  </button>
  <a
    class={`text-[32px] font-display-lg no-underline transition-colors duration-200 ${
      isHome ? "text-primary font-bold" : "text-on-surface hover:text-primary"
    }`}
    href={import.meta.env.BASE_URL}
  >
    Home
  </a>
  <a
    class={`text-[32px] font-display-lg no-underline transition-colors duration-200 ${
      isNotes ? "text-primary font-bold" : "text-on-surface hover:text-primary"
    }`}
    href={`${import.meta.env.BASE_URL}/notes`}
  >
    Notes
  </a>


  <div class="flex items-center gap-6 pt-4 border-t border-outline-variant/30 w-32 justify-center">
    <a href="https://x.com/ohwiredev" target="_blank" rel="noopener noreferrer" class="text-on-surface dark:text-on-background hover:text-primary dark:hover:text-primary-container transition-colors duration-200" aria-label="X (Twitter)">
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
    </a>
    <a href="https://github.com/ohwiredev" target="_blank" rel="noopener noreferrer" class="text-on-surface dark:text-on-background hover:text-primary dark:hover:text-primary-container transition-colors duration-200" aria-label="GitHub">
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
        <path d="M9 18c-4.51 2-5-2-7-2" />
      </svg>
    </a>
  </div>
</div>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('close-menu-btn');
  const menu = document.getElementById('mobile-menu');

  if (menuBtn && closeBtn && menu) {
    menuBtn.addEventListener('click', () => {
      menu.classList.remove('translate-x-full');
    });

    closeBtn.addEventListener('click', () => {
      menu.classList.add('translate-x-full');
    });

    // Close menu when a link is clicked
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('translate-x-full');
      });
    });
  }
</script>
