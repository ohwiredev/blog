---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

// Fetch all skills from content collection
const allSkills = await getCollection("skills");
---

<Layout
  title="Skills | ohwire"
  description="My autonomous capabilities and the agentic workflows I use to accelerate development."
>
  <section
    class="px-margin-mobile md:px-margin-desktop py-12 md:py-20 flex flex-col items-center text-center max-w-container-max mx-auto"
  >
    <h1
      class="font-display-lg text-[40px] leading-12 md:text-display-lg/18 mb-6 opacity-0 animate-fade-up"
    >
      My <span class="text-primary italic">Agentic</span> Skills
    </h1>
    <p
      class="font-body-lg text-body-lg text-secondary max-w-150 mb-10 opacity-0 animate-fade-up delay-100"
    >
      My autonomous capabilities and the workflows I use to accelerate development, from system planning to complex API integrations.
    </p>
  </section>

  <section
    class="px-margin-mobile md:px-margin-desktop pb-section-gap max-w-container-max mx-auto"
  >
    <div
      class="grid grid-cols-1 lg:grid-cols-2 group/grid auto-rows-fr gap-6"
      id="skills-grid"
    >
      {
        allSkills.map((skill) => (
          <div class="reveal h-full">
            <a
              href={skill.data.githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="spotlight-card h-full relative bg-outline-variant/30 rounded-xl p-[1px] block overflow-hidden group/card decoration-none no-underline cursor-pointer"
              style={`--brand-color: ${skill.data.color};`}
            >
              {/* Spotlight Gradient Background */}
              <div class="spotlight-glow absolute -inset-px opacity-0 group-hover/card:opacity-100 transition-opacity duration-300 pointer-events-none" />

              {/* Inner Content Area */}
              <div class="relative w-full h-full bg-surface-container rounded-[11px] p-6 md:p-8 flex flex-col md:flex-row items-start md:items-center text-left z-10 transition-transform duration-300 gap-6">
                {/* Icon Container */}
                <div class="relative z-10 w-14 h-14 shrink-0 flex items-center justify-center transition-transform duration-500 bg-surface/50 rounded-xl border border-outline-variant/30">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="w-8 h-8 opacity-80 group-hover/card:opacity-100 transition-opacity duration-300"
                    style={`color: ${skill.data.color};`}
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d={skill.data.iconPath} />
                  </svg>
                </div>

                {/* Text Elements */}
                <div class="flex flex-col flex-grow">
                  <div class="flex items-baseline gap-3 mb-1">
                    <span class="relative z-10 font-label-lg text-label-lg font-semibold group-hover/card:text-[var(--brand-color)] transition-colors duration-300">
                      {skill.data.title}
                    </span>
                    <span class="relative z-10 text-[11px] text-secondary uppercase tracking-widest font-label-sm px-2 py-0.5 rounded-md bg-secondary/10">
                      {skill.data.role}
                    </span>
                  </div>
                  <p class="relative z-10 font-body-md text-body-md text-secondary">
                    {skill.data.description}
                  </p>
                </div>
                
                {/* Optional Arrow or Action Indicator */}
                <div class="hidden md:flex relative z-10 shrink-0 text-secondary opacity-50 group-hover/card:opacity-100 group-hover/card:translate-x-1 transition-all duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                  </svg>
                </div>
              </div>
            </a>
          </div>
        ))
      }
    </div>
  </section>

  <style>
    .spotlight-glow {
      background: radial-gradient(
        circle at var(--mouse-x, 0px) var(--mouse-y, 0px),
        var(--brand-color),
        transparent 250px
      );
    }

    @media (prefers-reduced-motion: reduce) {
      .spotlight-card,
      .spotlight-glow,
      svg,
      div {
        /* biome-ignore lint/complexity/noImportantStyles: override required for reduced motion */
        transition: none !important;
      }
    }
  </style>

  <script>
    // Reveal Observer for scroll animations
    const observerOptions = {
      threshold: 0.1,
      rootMargin: "0px 0px -50px 0px",
    };

    const observer = new IntersectionObserver((entries) => {
      let delay = 0;
      const currentEntries = entries.filter((e) => e.isIntersecting);

      currentEntries.forEach((entry, index) => {
        // If they are part of a grid, stagger them
        const isGridItem = entry.target.parentElement?.id === "skills-grid";

        setTimeout(
          () => {
            entry.target.classList.add("active");
            observer.unobserve(entry.target);
          },
          isGridItem ? index * 50 : 0,
        );
      });
    }, observerOptions);

    document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));

    // Spotlight Effect
    const initSpotlight = () => {
      const cards = document.querySelectorAll(".spotlight-card");
      if (!cards.length) return;

      let targetX = -1000;
      let targetY = -1000;
      let currentX = -1000;
      let currentY = -1000;

      document.addEventListener("mousemove", (e) => {
        targetX = e.clientX;
        targetY = e.clientY;
      });

      const updateSpotlight = () => {
        currentX += (targetX - currentX) * 0.15;
        currentY += (targetY - currentY) * 0.15;

        for (let i = 0; i < cards.length; i++) {
          const card = cards[i] as HTMLElement;
          const rect = card.getBoundingClientRect();
          const x = currentX - rect.left;
          const y = currentY - rect.top;
          card.style.setProperty("--mouse-x", `${x}px`);
          card.style.setProperty("--mouse-y", `${y}px`);
        }
        requestAnimationFrame(updateSpotlight);
      };

      requestAnimationFrame(updateSpotlight);
    };

    // Run on initial load
    initSpotlight();

    // Run when Astro swaps pages (if view transitions are used later)
    document.addEventListener("astro:page-load", initSpotlight);
  </script>
</Layout>
