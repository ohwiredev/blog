---
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import {
	ArrowLeft,
	ArrowUpRight,
	Bookmark,
	ChevronRight,
	Globe,
	Mail,
	Share2,
} from "@lucide/astro";
import Newsletter from "../../components/Newsletter.astro";
import { CATEGORIES, isValidCategory } from "../../config/categories";
import Layout from "../../layouts/Layout.astro";
import { getReadingTime } from "../../utils/readingTime";

export async function getStaticPaths() {
	const notes = await getCollection("notes");

	// Validate categories at build/run time
	for (const note of notes) {
		if (!isValidCategory(note.data.category)) {
			throw new Error(
				`[Invalid Category] The blog post "${note.id}" has an invalid category "${note.data.category}". Allowed categories are: ${CATEGORIES.join(", ")}`,
			);
		}
	}

	return notes.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);

const readTime = post.data.readTime || getReadingTime(post.body || "");

// Fetch related articles (excluding the current one)
const allNotes = await getCollection("notes");

// Validate related notes categories at build/run time
for (const note of allNotes) {
	if (!isValidCategory(note.data.category)) {
		throw new Error(
			`[Invalid Category] The blog post "${note.id}" has an invalid category "${note.data.category}". Allowed categories are: ${CATEGORIES.join(", ")}`,
		);
	}
}

const relatedNotes = allNotes.filter((note) => note.id !== post.id).slice(0, 2); // Get first 2 related articles
---

<Layout title={`${post.data.title} | ohwire`} description={post.data.description} image={post.data.image}>
  <!-- Reading Progress Bar -->
  <div class="fixed top-20 left-0 w-full h-1 z-50 pointer-events-none">
    <div id="progress-bar" class="h-full bg-primary-container w-0 transition-all duration-75"></div>
  </div>

  <!-- Breadcrumbs -->
  <section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-8">
    <nav class="flex items-center gap-2 text-label-md font-label-md text-secondary">
      <a class="hover:text-primary transition-colors no-underline" href="/">Home</a>
      <ChevronRight class="w-3 h-3 select-none" />
      <a class="hover:text-primary transition-colors no-underline" href={`/notes?category=${post.data.category}`}>{post.data.category}</a>
      <ChevronRight class="w-3 h-3 select-none" />
      <span class="text-on-surface truncate max-w-50 md:max-w-none">{post.data.title}</span>
    </nav>
  </section>

  <!-- Article Header -->
  <article class="pb-section-gap">
    <header class="content-column px-margin-mobile md:px-0 text-center md:text-left">
      <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface mb-8 leading-[1.1] md:leading-[1.12]">
        {post.data.title}
      </h1>

      <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 border-b border-outline-variant pb-8 mb-12">
        <div class="flex items-center gap-4 justify-center md:justify-start">
          {post.data.authorImage && (
            <div class="w-12 h-12 rounded-full bg-secondary-container flex items-center justify-center overflow-hidden">
              <Image
                alt={post.data.author}
                class="w-full h-full object-cover"
                src={post.data.authorImage}
                width={48}
                height={48}
              />
            </div>
          )}
          <div class="text-left">
            <p class="font-label-md text-label-md text-on-surface">{post.data.author}</p>
            <p class="font-body-md text-body-md text-secondary">
              {post.data.publishDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })} • {readTime}
            </p>
          </div>
        </div>
      </div>
    </header>

    <!-- Hero Image -->
    {post.data.image && (
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-section-gap">
        <div class="w-full aspect-video rounded-xl md:rounded-[32px] overflow-hidden ambient-shadow">
          <Image
            alt={post.data.imageAlt || post.data.title}
            class="w-full h-full object-cover"
            src={post.data.image}
            width={1200}
            height={675}
          />
        </div>
      </div>
    )}

    <!-- Body Content -->
    <div class="content-column px-margin-mobile md:px-0">
      <div class="prose-editorial font-body-lg text-body-lg text-on-surface-variant space-y-8 leading-relaxed">
        <Content />
      </div>

      <!-- Footer Article Navigation -->
      <div class="mt-section-gap pt-12 border-t border-outline-variant flex flex-col md:flex-row justify-between items-center gap-8">
        <a class="flex items-center gap-2 font-label-md text-label-md text-primary hover:gap-4 transition-all duration-300 no-underline cursor-pointer" href="/notes">
          <ArrowLeft class="w-5 h-5" />
          Back to all notes
        </a>
        <div class="flex items-center gap-4">
          <span class="font-label-md text-label-md text-secondary">Share this article:</span>
          <div class="flex gap-2">
            <a class="w-10 h-10 rounded-full bg-surface-container-highest flex items-center justify-center hover:bg-primary-container hover:text-white transition-colors duration-200 cursor-pointer" href="#" aria-label="Web">
              <Globe class="w-[18px] h-[18px]" />
            </a>
            <a class="w-10 h-10 rounded-full bg-surface-container-highest flex items-center justify-center hover:bg-primary-container hover:text-white transition-colors duration-200 cursor-pointer" href="#" aria-label="Email">
              <Mail class="w-[18px] h-[18px]" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </article>

  <!-- More to Read Section -->
  <section class="bg-surface-container-lowest py-section-gap">
    <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
      <div class="flex justify-between items-end mb-12">
        <h2 class="font-headline-md text-headline-md text-on-surface">More to read</h2>
        <a class="font-label-md text-label-md text-primary border-b border-primary pb-1 no-underline" href="/notes">View Archives</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">
        {relatedNotes.map((note) => (
          <article class="bg-white rounded-xl overflow-hidden ambient-shadow card-hover transition-all duration-300 flex flex-col h-full">
            {note.data.image && (
              <div class="aspect-[16/10] overflow-hidden">
                <Image
                  alt={note.data.imageAlt || note.data.title}
                  class="w-full h-full object-cover"
                  src={note.data.image}
                  width={800}
                  height={500}
                />
              </div>
            )}
            <div class="p-8 flex flex-col flex-grow">
              <span class="font-label-md text-label-md text-primary mb-3 uppercase tracking-wider">{note.data.category}</span>
              <h3 class="font-headline-sm text-headline-sm text-on-surface mb-4 flex-grow leading-snug">
                {note.data.title}
              </h3>
              <p class="font-body-md text-body-md text-secondary mb-6 line-clamp-2">
                {note.data.description}
              </p>
              <a class="font-label-md text-label-md text-on-surface flex items-center gap-2 hover:text-primary transition-colors no-underline mt-auto" href={`/notes/${note.id}`}>
                Read more <ArrowUpRight class="w-4 h-4" />
              </a>
            </div>
          </article>
        ))}

        <!-- Newsletter Card (3rd column) -->
        <Newsletter variant="card" />
      </div>
    </div>
  </section>

  <!-- Script for Reading Progress -->
  <script>
    const progressBar = document.getElementById('progress-bar');

    window.addEventListener('scroll', () => {
      if (!progressBar) return;
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
      progressBar.style.width = scrolled + '%';
    });
  </script>

  <style is:global>
    /* Styling rules for content within the MDX prose container */
    .prose-editorial h2 {
      font-family: var(--font-headline-md);
      font-size: var(--text-headline-md);
      color: var(--color-on-surface);
      margin-top: 3rem;
      margin-bottom: 1.5rem;
    }
    .prose-editorial p {
      margin-bottom: 1.5rem;
    }
    .prose-editorial a {
      color: var(--color-primary);
      text-decoration: underline;
    }
  </style>
</Layout>
